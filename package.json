{
  "name": "nes.css",
  "description": "NES.css is NES-style CSS Framework.",
  "scripts": {
    "dev": "sass --watch --update --style=expanded scss/nes.scss:css/nes.css",
    "build": "sass --no-source-map --style=compressed scss/nes.scss:css/nes.css"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/nostalgic-css/NES.css.git"
  },
  "keywords": [
    "css",
    "scss",
    "nes",
    "framework"
  ],
  "author": "BcRikko (https://github.com/Bcrikko)",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/nostalgic-css/NES.css/issues"
  },
  "homepage": "https://github.com/nostalgic-css/NES.css#readme",
  "stylelint": {
    "plugins": [
      "stylelint-scss",
      "stylelint-prettier"
    ],
    "extends": [
      "stylelint-config-standard",
      "stylelint-config-recess-order",
      "stylelint-prettier/recommended"
    ],
    "rules": {
      "prettier/prettier": true,
      "string-quotes": "double",
      "at-rule-no-unknown": null,
      "scss/at-rule-no-unknown": true
    },
    "ignoreFiles": [
      "docs/*"
    ]
  },
  "devDependencies": {
    "sass": "^1.53.0"
  }
}
